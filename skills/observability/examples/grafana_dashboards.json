            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(ecto_repo_query_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "50th percentile",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Seconds"},
          {"format": "short"}
        ]
      },
      {
        "title": "Database Query Rate",
        "type": "graph",
        "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(ecto_repo_query_total[5m]))",
            "legendFormat": "Queries/s",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Queries/s"},
          {"format": "short"}
        ]
