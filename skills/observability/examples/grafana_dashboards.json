        "title": "WebSocket Connections",
        "type": "graph",
        "gridPos": {"x": 12, "y": 32, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(websocket_connections_total[5m])",
            "legendFormat": "Connections/s",
            "refId": "A"
          },
          {
            "expr": "rate(websocket_messages_total[5m])",
            "legendFormat": "Messages/s",
